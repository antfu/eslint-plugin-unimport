{
  "name": "eslint-plugin-unimport",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@11.1.3",
  "description": "Insert imports automatically from Unimport in ESLint.",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/antfu",
  "homepage": "https://github.com/antfu/eslint-plugin-unimport#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antfu/eslint-plugin-unimport.git"
  },
  "bugs": "https://github.com/antfu/eslint-plugin-unimport/issues",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "unimport"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "test": "vitest",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "eslint": "^10.0.0 || ^9.0.0 || ^8.45.0"
  },
  "dependencies": {
    "@typescript-eslint/scope-manager": "^8.59.4",
    "@typescript-eslint/utils": "^8.59.4",
    "obug": "^2.1.1",
    "pathe": "^2.0.3",
    "unimport": "^6.3.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@antfu/ni": "^30.1.0",
    "@antfu/utils": "^9.3.0",
    "@types/eslint": "^9.6.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@vueuse/core": "^14.3.0",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unimport": "workspace:*",
    "eslint-plugin-unused-imports": "^4.4.1",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "lint-staged": "^17.0.5",
    "pnpm": "^11.1.3",
    "publint": "^0.3.21",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
